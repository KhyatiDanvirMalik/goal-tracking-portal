# ============================================
# APP CONFIG
# ============================================

PORT=4000
NODE_ENV=production

# ============================================
# JWT AUTH
# ============================================

JWT_SECRET=goal_tracking_super_secret_key_2026

# ============================================
# FRONTEND URL (update after Render frontend deploy)
# ============================================

CLIENT_URL=https://YOUR_FRONTEND_RENDER_URL.onrender.com

# ============================================
# RATE LIMITING
# ============================================

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200

# ============================================
# MYSQL DATABASE  (from Railway → Variables tab)
# ============================================

DB_HOST=your-railway-mysql-host.railway.app
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_railway_mysql_password
DB_NAME=railway
DB_SSL=true
